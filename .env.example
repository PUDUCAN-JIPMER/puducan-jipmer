# ─── Firebase Configuration ────────────────────────────────────────────────────
# All values come from: Firebase Console → Project Settings → Your apps → Config
# Guide: https://firebase.google.com/docs/web/setup#config-object

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional — only needed if Google Analytics is enabled in your Firebase project
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ─── DigiLocker OAuth (Production — Phase 3) ────────────────────────────────────
# Obtain credentials from NIC / MeitY after API access approval:
# https://partners.digilocker.gov.in/
#
# IMPORTANT: These values must NEVER be prefixed with NEXT_PUBLIC_.
# All DigiLocker API calls must be proxied through server-side API routes.
# Tokens must NEVER reach the browser.
#
DIGILOCKER_CLIENT_ID=
DIGILOCKER_CLIENT_SECRET=
DIGILOCKER_REDIRECT_URI=https://your-domain.com/api/digilocker/callback
# Override to use sandbox: https://sandbox.digitallocker.gov.in
DIGILOCKER_BASE_URL=https://api.digitallocker.gov.in

# ─── DigiLocker Aadhaar Encryption ──────────────────────────────────────────────
# AES-256-GCM key for encrypting raw Aadhaar UIDs before storage.
# Must be exactly 64 hex characters (32 bytes).
# Generate:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If absent, a DEV-ONLY base64 placeholder is used (NOT production-safe).
DIGILOCKER_AADHAAR_KEY=

# ─── DigiLocker Feature Flag (Client-safe) ──────────────────────────────────────
# Set to "true" in production to enable the real DigiLocker OAuth popup flow.
# Set to "false" (or leave unset) in development to use the Mock + OTP flow.
# This is safe to expose to the client — it contains no secrets.
NEXT_PUBLIC_DIGILOCKER_ENABLED=false

# ─── ABHA / Ayushman Bharat (Production — Phase 4) ──────────────────────────────
# Obtain from NHA (National Health Authority) after ABDM integration approval:
# https://sandbox.abdm.gov.in/
#
# These are also server-side only — never expose in NEXT_PUBLIC_ vars.
#
ABHA_CLIENT_ID=
ABHA_CLIENT_SECRET=
ABHA_API_BASE_URL=https://healthidsbx.abdm.gov.in/api

# ─── SMS Provider (MSG91) ────────────────────────────────────────────────────────
# Used for OTP delivery. Obtain from https://msg91.com/
# Leave unset in development — OTP will be returned in the API response body.
MSG91_API_KEY=
MSG91_TEMPLATE_ID=

# ─── App URL (used for OAuth redirect URIs and email links) ─────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Firebase Admin SDK (for server-side Firestore) ─────────────────────────────
# Download the service account JSON from:
# Firebase Console → Project Settings → Service accounts → Generate new private key
# Then inline the JSON as a single line:
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key":"...",...}'
FIREBASE_SERVICE_ACCOUNT_JSON=
